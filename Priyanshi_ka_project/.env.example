# Root-level convenience file. Copy contents into backend/.env and frontend/.env.

# --- Backend ---
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/team_task_manager
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# --- Frontend ---
VITE_API_URL=http://localhost:5000/api
